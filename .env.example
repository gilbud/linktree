# Secret untuk JWT token (wajib di production)
JWT_SECRET=ubah-dengan-string-random-panjang

# Otomatis terisi saat menghubungkan Upstash Redis / Vercel KV di Vercel
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# atau (Vercel KV):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Opsional: URL API custom (default: /api)
# VITE_API_URL=/api
